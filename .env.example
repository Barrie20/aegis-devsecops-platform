# ============================================
# Environment Variables - EXAMPLE FILE
# ============================================
# IMPORTANT: Copy this to .env and fill in real values
# NEVER commit .env to Git (it's in .gitignore)
#
# This file (.env.example) IS committed to Git
# so new developers know what variables are needed.
# ============================================

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=debug
API_PORT=8000

# --- Database ---
DATABASE_URL=postgresql://aegis:localdev@localhost:5432/aegis_db

# --- Redis ---
REDIS_URL=redis://:localdev@localhost:6379/0

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# --- AWS (for Terraform/deployment) ---
# AWS_PROFILE=aegis-dev
# AWS_REGION=us-east-1
